class Solution {
public:
    long long countSubarrays(vector<int>& nums, int k) {
        int n = nums.size(),tar = 0 , l = 0,cnt = 0;
        for(int i = 0 ; i < n ; i++){
            if(nums[i] > tar)
                tar = nums[i];
        }
        long long res = 0;
        for(int r = 0 ; r < n ; r++){
            if(nums[r] == tar)
                cnt++;
            while(cnt > k-1 ){
                if(nums[l] == tar)
                    cnt--;
                l++;
            }
            res += r-l+1;
        }
        return ( 1LL *n*(n+1))/2 - res;
    }
};
