class Solution {
    public int AtMostK(int[] nums,int k){
        int n = nums.length;
        int l = 0, cnt = 0,res = 0;
        for(int r = 0 ; r < n; r++){
            if(nums[r] % 2 == 1) cnt++;
            while(cnt > k){
                if(nums[l] % 2 == 1)
                    cnt--;
                l++;
            }
            res += r-l+1;
        }
        return res;
    } 
    public int numberOfSubarrays(int[] nums, int k) {
        int AtMost = AtMostK(nums,k);
        int StrictlyK = AtMostK(nums,k-1);
        return AtMost - StrictlyK;
    }
}
