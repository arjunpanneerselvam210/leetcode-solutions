class Solution {
public:
    vector<int> partitionLabels(string s) {
        int n = s.size();
        int arr[26];
        for(int i = 0 ; i < n ; i++)
            arr[s[i] - 'a'] = i;
        vector<int> res;
        int start = 0 , end = -1;
        for(int i = 0 ; i < n ; i++){
            end = max(end, arr[s[i] - 'a']);
            if(end == i){
                res.push_back(end - start + 1);
                start = end + 1;
            }
        }
        return res;
    }
};
