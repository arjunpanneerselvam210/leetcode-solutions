class Solution {
public:
    string frequencySort(string s) {
        unordered_map<char,int>mp;
        for(auto i : s)
            mp[i]++;
        priority_queue<pair<int,char>>pq;
        for(auto i : mp)
            pq.push({i.second , i.first});
        string res = "";
        while(!pq.empty()){
            res.append(pq.top().first , pq.top().second);
            pq.pop();
        }
        return res;
    }
};
