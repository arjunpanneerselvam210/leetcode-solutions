class Solution {
public:
    long long maximumSubarraySum(vector<int>& nums, int k) {
        int n = nums.size() , left = 0 ;
        long long maxVal = 0 , sum = 0;
        unordered_map<int,int> mp;
        for(int right = 0 ; right < n ; right++){
            sum += nums[right];
            mp[nums[right]]++;
            if(right - left + 1 == k){
                if(mp.size() == k)
                    maxVal = max(maxVal , sum);
                mp[nums[left]]--;
                if(mp[nums[left]] == 0)
                    mp.erase(nums[left]);
                sum -= nums[left++];
            }
        }
        return maxVal;
    }
};
