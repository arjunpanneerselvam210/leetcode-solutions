class Solution {
public:
    int myAtoi(string s) {
        int n = s.size() , flag = 1 , i = 0;
        while(i < n && s[i] == ' ') i++;
        if(i == n)  return 0;
        if(i < n && s[i] == '-' || s[i] == '+'){
            if(s[i] == '-') flag = -1;
            i++;
        }
        while(i < n && s[i] == '0') i++;
        if(i == n)  return 0;
        long res = 0;
        while(i < n && s[i] >= '0' && s[i] <= '9'){
            res = res * 10 + (s[i] - '0');
            if(res > INT_MAX)
                return flag == 1 ? INT_MAX : INT_MIN;
            cout<<res<<" ";
            i++;
        }
        return flag * res;
    }
};
