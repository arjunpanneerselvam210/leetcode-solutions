class Solution {
public:
    double findMaxAverage(vector<int>& nums, int k) {
        int n = nums.size() , sum = 0 , left = 0;
        if(n == 1)  return (double)nums[0];
        double maxVal = INT_MIN;
        for(int right = 0 ; right < n ; right++){
            sum += nums[right];
            if((right - left + 1) == k){
                maxVal = max(maxVal , (double)(sum)/k );
                sum -= nums[left++];
            }
        }
        return maxVal;
    }
};
