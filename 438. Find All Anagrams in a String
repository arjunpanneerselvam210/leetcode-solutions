class Solution {
public:
    vector<int> findAnagrams(string s, string p) {
        int n = s.size() , m = p.size();
        vector<int>arr1(26,0);
        vector<int>arr2(26,0);
        vector<int>res;
        for(int i = 0 ; i < m ; i++)
            arr2[p[i] - 'a']++;
        int left = 0 ;
        for(int right = 0 ; right < n ; right++){
            arr1[s[right] - 'a']++;
            if(right - left + 1 > m)
                arr1[s[left++] - 'a']--;
            if(arr1 == arr2)
                res.push_back(left);   
        }
        return res;
    }
};
